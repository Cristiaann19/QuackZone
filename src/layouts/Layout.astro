---
import "../styles/global.css";

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <title>{title}</title>
    </head>

    <body>
        <div class="bg-[#0d0d0d]">
            <slot />
        </div>
    </body>
</html>
