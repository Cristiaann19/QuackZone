---
import { Image } from "astro:assets";

export interface Game {
  id: number;
  title: string;
  price: number;
  originalPrice?: number;
  image: string;
  rating: number;
  platform: string[];
  genre: string;
  isNew?: boolean;
  discount?: number;
}

const { game } = Astro.props as { game: Game };
---

<div
  class="group animate-fadeIn cursor-pointer rounded-(--radius-md) bg-surface-2 p-4 shadow-card transition-all duration-300 hover:-translate-y-2 hover:shadow-xl"
>
  <div class="relative overflow-hidden">
    <Image
      src={game.image}
      alt={game.title}
      width={400}
      height={300}
      loading={"lazy"}
      class="w-full transition-transform duration-500 group-hover:scale-110"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-[#1a1a1a] via-transparent to-transparent opacity-60"
    >
    </div>
  </div>

  <div class="px-4 py-3">
    <h3 class="text-lg font-semibold text-white mb-2">{game.title}</h3>
    <p class="text-2xl font-bold text-white">${game.price}</p>
    <button class="mt-3 w-full py-2 bg-primary text-white rounded-lg">
      Comprar
    </button>
  </div>
</div>
