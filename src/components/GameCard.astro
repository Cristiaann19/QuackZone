---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

export interface Game {
  id: number;
  title: string;
  price: number;
  originalPrice?: number;
  image: string;
  rating: number;
  platform: string[];
  genre: string;
  isNew?: boolean;
  discount?: number;
}

const { game } = Astro.props as { game: Game };
---

<div
  class="rounded-xl overflow-hidden group cursor-pointer bg-[#1a1a1a] border border-[#2a2a2a] flex flex-col transition-transform duration-200 hover:-translate-y-1"
>
  <div class="relative overflow-hidden aspect-[3/4]">
    <Image
      src={game.image}
      alt={game.title}
      width={400}
      height={300}
      loading="eager"
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
    <div class="absolute top-2 left-2 flex flex-col gap-1">
      {
        game.isNew && (
          <span class="text-xs px-2 py-0.5 rounded font-bold text-white bg-[#f96300]">
            Nuevo
          </span>
        )
      }
      {
        game.discount && (
          <span class="text-xs px-2 py-0.5 rounded font-bold text-white bg-[#22c55e]">
            {game.discount}%
          </span>
        )
      }
    </div>
    <button
      class="absolute top-2 right-2 p-1.5 rounded-full opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer"
      style="background: rgba(0, 0, 0, 0.7);"
    >
      <Icon name="lucide:heart" class="w-4 h-4 text-white" />
    </button>
    <div class="absolute bottom-2 left-2 flex gap-1">
      {
        game.platform.map((platform) => (
          <span
            class="text-xs px-1.5 py-0.5 rounded font-medium"
            style="background: rgba(0,0,0,0.75); color: #ccc"
          >
            {platform}
          </span>
        ))
      }
    </div>
  </div>

  <!-- Info -->
  <div class="p-3 flex flex-col gap-2 flex-1">
    <!-- Header -->
    <h3 class="text-white text-sm font-semibold leading-tight line-clamp-2">
      {game.title}
    </h3>
    <div class="flex items-center gap-1">
      <Icon
        name="lucide:star"
        class="w-4 h-4 fill-yellow-400 text-yellow-400"
      />
      <span class="text-sm font-medium text-white" style="color: #888;"
        >{game.rating}</span
      >
    </div>
    <div class="flex items-center justify-between mt-auto">
      <div class="flex items-baseline">
        <span class="font-bold text-[#f96300]">S/.{game.price.toFixed(2)}</span>
        {
          game.originalPrice && (
            <span class="text-xs ml-1.5 line-through text-[#888888]">
              S/.{game.originalPrice.toFixed(2)}
            </span>
          )
        }
      </div>

      <button
        class="flex
    items-center
    gap-1
    px-3
    py-1.5
    rounded-lg
    text-xs
    font-semibold
    text-white
    transition-opacity
    hover:opacity-80
    bg-[#f96300]
    cursor-pointer"
      >
        Añadir
        <Icon name="lucide:shopping-cart" class="w-4 h-4" />
      </button>
    </div>
  </div>
</div>
